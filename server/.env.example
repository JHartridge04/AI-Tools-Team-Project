# ──────────────────────────────────────────────────────────────────────────────
# Adaptive Wellness Companion — Server Environment Variables
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your Anthropic API key (get one at https://console.anthropic.com)
#   3. NEVER commit the real .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Your Anthropic API key — required for the AI therapist and Cultural Mirror features.
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Your OpenAI API key — required for DALL-E 3 image generation in Dream Visualization.
# Without this key the dream text will still work, but no images will be generated.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_key_here

# (Optional) Port the proxy server listens on. Default: 3001
# PORT=3001

# (Optional) Which origin can call this server. Default: http://localhost:3000
# ALLOWED_ORIGIN=http://localhost:3000
